# Secrets for the y0 stack. Copy to .env (git-ignored, chmod 600) on y0.
# AUTH_CLIENT_SECRET — Keycloak confidential client secret for `fwknop-ui`
#   (Bitwarden: "fwknop-ui OIDC client (Keycloak fwknop realm)").
AUTH_CLIENT_SECRET=changeme-from-bitwarden
# AUTH_SESSION_SECRET — random cookie-signing secret. Generate with:
#   openssl rand -hex 32
AUTH_SESSION_SECRET=changeme-openssl-rand-hex-32
